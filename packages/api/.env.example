PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Mock mode (no Fabric network required) ───────────────────────────────────
# Set to true to run with the in-memory mock store + built-in simulator.
# The dashboard will be fully functional without a Hyperledger Fabric network.
USE_MOCK=true
SIM_INTERVAL_MS=2000

# ── Hyperledger Fabric (only needed when USE_MOCK=false) ─────────────────────
CHANNEL_NAME=mychannel
CHAINCODE_NAME=grid-monitor
WALLET_PATH=./wallet
CONNECTION_PROFILE_PATH=./connection-profile.json
